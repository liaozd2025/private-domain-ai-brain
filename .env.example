# ===== LLM 配置 =====
# 主力模型通过 OpenAI 兼容接口接入
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# 如需切换到其他提供商，可再填写对应密钥
ANTHROPIC_API_KEY=sk-ant-xxx
DASHSCOPE_API_KEY=sk-xxx

# 主力模型选择: claude / qwen / openai
PRIMARY_LLM=openai
PRIMARY_MODEL=Pro/MiniMaxAI/MiniMax-M2.5

# 分类器模型 (轻量，用于路由)
ROUTER_LLM=qwen
ROUTER_MODEL=qwen-plus

# 视觉模型 (图片/截图/海报分析)
VISION_LLM=openai
VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# ===== 数据库配置 =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_brain
POSTGRES_USER=ai_brain
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg://ai_brain:changeme@localhost:5432/ai_brain

# ===== Milvus 配置 =====
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=
# 或使用 Zilliz Cloud
# MILVUS_URI=https://xxx.zillizcloud.com
# MILVUS_TOKEN=xxx

MILVUS_COLLECTION_NAME=private_domain_knowledge

# ===== Embedding / Reranker =====
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_DEVICE=cpu
# 如有 GPU: cuda

# ===== 文件存储 =====
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ===== API 配置 =====
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# ===== 企微 Webhook =====
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# ===== OpenClaw 配置 =====
OPENCLAW_BASE_URL=https://api.openclaw.io
OPENCLAW_API_KEY=

# ===== 监控 (可选) =====
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
ENABLE_TRACING=false

# ===== 应用配置 =====
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-this-in-production
