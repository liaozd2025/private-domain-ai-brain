# ===== LLM 配置 =====
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# ===== 模型配置 =====
PRIMARY_LLM=openai
PRIMARY_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
ROUTER_LLM=openai
ROUTER_MODEL=Qwen/Qwen2.5-7B-Instruct
VISION_LLM=openai
VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct


# ===== 应用环境 =====
APP_ENV=development
AUTH_ENABLED=false
SECRET_KEY=dev-secret-key
LOG_LEVEL=INFO

# ===== API 配置 =====
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ===== 数据库配置 =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_brain
POSTGRES_USER=ai_brain
POSTGRES_PASSWORD=changeme

# ===== Milvus / MinIO 配置 =====
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=private_domain_knowledge
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_HEALTH_PORT=9091

# ===== 文件存储 =====
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ===== 可选渠道配置 =====
OPENCLAW_BASE_URL=https://api.openclaw.io
OPENCLAW_API_KEY=
OPENCLAW_WEBHOOK_SECRET=dev-openclaw-secret
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# ===== 阿里云 OSS =====
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_PREFIX=uploads/
